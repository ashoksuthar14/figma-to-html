{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DesignSpec",
  "description": "Design specification extracted from a Figma frame",
  "type": "object",
  "required": ["frameId", "frameName", "width", "height", "backgroundColor", "nodes", "assets", "metadata"],
  "properties": {
    "frameId": { "type": "string" },
    "frameName": { "type": "string" },
    "width": { "type": "number", "minimum": 0 },
    "height": { "type": "number", "minimum": 0 },
    "backgroundColor": { "$ref": "#/definitions/Color" },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/definitions/DesignNode" }
    },
    "assets": {
      "type": "array",
      "items": { "$ref": "#/definitions/AssetReference" }
    },
    "metadata": {
      "type": "object",
      "required": ["figmaFileKey", "exportedAt", "pluginVersion"],
      "properties": {
        "figmaFileKey": { "type": "string" },
        "exportedAt": { "type": "string", "format": "date-time" },
        "pluginVersion": { "type": "string" }
      }
    }
  },
  "definitions": {
    "Color": {
      "type": "object",
      "required": ["r", "g", "b", "a"],
      "properties": {
        "r": { "type": "number", "minimum": 0, "maximum": 1 },
        "g": { "type": "number", "minimum": 0, "maximum": 1 },
        "b": { "type": "number", "minimum": 0, "maximum": 1 },
        "a": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "Fill": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["SOLID", "GRADIENT_LINEAR", "GRADIENT_RADIAL", "GRADIENT_ANGULAR", "IMAGE"] },
        "color": { "$ref": "#/definitions/Color" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "gradientStops": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "position": { "type": "number" },
              "color": { "$ref": "#/definitions/Color" }
            }
          }
        },
        "gradientTransform": {
          "type": "array",
          "items": { "type": "array", "items": { "type": "number" } }
        },
        "imageRef": { "type": "string" },
        "scaleMode": { "type": "string", "enum": ["FILL", "FIT", "CROP", "TILE"] }
      }
    },
    "Stroke": {
      "type": "object",
      "properties": {
        "color": { "$ref": "#/definitions/Color" },
        "weight": { "type": "number" },
        "align": { "type": "string", "enum": ["INSIDE", "OUTSIDE", "CENTER"] }
      }
    },
    "Effect": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["DROP_SHADOW", "INNER_SHADOW", "LAYER_BLUR", "BACKGROUND_BLUR"] },
        "color": { "$ref": "#/definitions/Color" },
        "offset": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "radius": { "type": "number" },
        "spread": { "type": "number" },
        "visible": { "type": "boolean" }
      }
    },
    "TextSegment": {
      "type": "object",
      "required": ["start", "end", "fontFamily", "fontSize", "fontWeight", "color"],
      "properties": {
        "start": { "type": "integer" },
        "end": { "type": "integer" },
        "fontFamily": { "type": "string" },
        "fontSize": { "type": "number" },
        "fontWeight": { "type": "integer" },
        "fontStyle": { "type": "string", "enum": ["normal", "italic"], "default": "normal" },
        "lineHeight": { "oneOf": [{ "type": "number" }, { "type": "string", "enum": ["AUTO"] }] },
        "letterSpacing": { "type": "number", "default": 0 },
        "color": { "$ref": "#/definitions/Color" },
        "textDecoration": { "type": "string", "enum": ["NONE", "UNDERLINE", "STRIKETHROUGH"], "default": "NONE" }
      }
    },
    "DesignNode": {
      "type": "object",
      "required": ["id", "name", "type", "visible", "opacity", "bounds", "layout", "style", "children"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["FRAME", "TEXT", "RECTANGLE", "ELLIPSE", "VECTOR", "GROUP", "INSTANCE", "COMPONENT"]
        },
        "visible": { "type": "boolean" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "bounds": {
          "type": "object",
          "required": ["x", "y", "width", "height"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "width": { "type": "number" },
            "height": { "type": "number" }
          }
        },
        "layout": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "type": "string", "enum": ["NONE", "AUTO_LAYOUT", "ABSOLUTE"] },
            "direction": { "type": "string", "enum": ["HORIZONTAL", "VERTICAL"] },
            "gap": { "type": "number" },
            "padding": {
              "type": "object",
              "properties": {
                "top": { "type": "number" },
                "right": { "type": "number" },
                "bottom": { "type": "number" },
                "left": { "type": "number" }
              }
            },
            "primaryAxisAlign": { "type": "string", "enum": ["MIN", "CENTER", "MAX", "SPACE_BETWEEN"] },
            "counterAxisAlign": { "type": "string", "enum": ["MIN", "CENTER", "MAX"] },
            "wrap": { "type": "boolean" },
            "constraints": {
              "type": "object",
              "properties": {
                "horizontal": { "type": "string" },
                "vertical": { "type": "string" }
              }
            }
          }
        },
        "style": {
          "type": "object",
          "properties": {
            "fills": { "type": "array", "items": { "$ref": "#/definitions/Fill" } },
            "strokes": { "type": "array", "items": { "$ref": "#/definitions/Stroke" } },
            "borderRadius": {
              "type": "object",
              "properties": {
                "tl": { "type": "number" },
                "tr": { "type": "number" },
                "br": { "type": "number" },
                "bl": { "type": "number" }
              }
            },
            "effects": { "type": "array", "items": { "$ref": "#/definitions/Effect" } },
            "blendMode": { "type": "string" },
            "overflow": { "type": "string", "enum": ["VISIBLE", "HIDDEN", "SCROLL"] }
          }
        },
        "text": {
          "type": "object",
          "properties": {
            "content": { "type": "string" },
            "segments": { "type": "array", "items": { "$ref": "#/definitions/TextSegment" } },
            "textAlign": { "type": "string", "enum": ["LEFT", "CENTER", "RIGHT", "JUSTIFIED"] },
            "verticalAlign": { "type": "string", "enum": ["TOP", "CENTER", "BOTTOM"] }
          }
        },
        "component": {
          "type": "object",
          "properties": {
            "componentId": { "type": "string" },
            "variantProperties": { "type": "object", "additionalProperties": { "type": "string" } },
            "isInstance": { "type": "boolean" }
          }
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/definitions/DesignNode" }
        }
      }
    },
    "AssetReference": {
      "type": "object",
      "required": ["nodeId", "fileName", "format"],
      "properties": {
        "nodeId": { "type": "string" },
        "fileName": { "type": "string" },
        "format": { "type": "string", "enum": ["PNG", "SVG", "JPG"] },
        "data": { "type": "string", "description": "Base64 encoded asset data" }
      }
    }
  }
}
