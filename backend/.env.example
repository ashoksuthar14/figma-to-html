# =============================================================
# Backend Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================

# ── Required ──────────────────────────────────────────────────

# OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Figma Personal Access Token (https://www.figma.com/developers/api#access-tokens)
FIGMA_ACCESS_TOKEN=figd_your-figma-access-token-here

# ── Optional (defaults shown) ────────────────────────────────

# Server
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000

# OpenAI model (gpt-4o, gpt-5.2, etc.)
# OPENAI_MODEL=gpt-5.2
# OPENAI_MAX_TOKENS=16384
# OPENAI_TEMPERATURE=0.1

# Pipeline tuning
# MAX_FIX_ITERATIONS=5
# PIXEL_MISMATCH_THRESHOLD=15.0
# SSIM_THRESHOLD=0.70

# Use deterministic code generation (faster, no GPT call for layout)
# USE_DETERMINISTIC_GENERATION=True

# Logging
# LOG_LEVEL=INFO
# LOG_FILE=

# Directories
# OUTPUT_DIR=./output
# TEMP_DIR=./temp
